# ── Supabase ─────────────────────────────────────────────────────────────────
# Public values (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — used by /api/pm/* routes for admin operations.
# REQUIRED for: invoice generation, vendor CRUD, polls, communal/inventory CRUD,
# AI categorization webhooks. Without it API routes fall back to anon key and
# RLS policies will block writes.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Anthropic ────────────────────────────────────────────────────────────────
# Used by /api/ai-* and /api/pm/* routes that call Claude.
ANTHROPIC_API_KEY=sk-ant-your-key

# ── Branding (optional) ──────────────────────────────────────────────────────
# Override these to white-label the UI for a specific developer/customer.
# Used in: sidebar logos, login pages, page <title>, AI email signature.
# Leave unset to keep the default "PropTech UZ".
NEXT_PUBLIC_BRAND_NAME=PropTech UZ
NEXT_PUBLIC_BRAND_TAGLINE=Real Estate Suite
NEXT_PUBLIC_BRAND_LEGAL_NAME=PropTech UZ
